# ===== LLM =====
# 二选一填写
QIANWEN_API_KEY=your_qianwen_api_key_here
# ZHIPU_API_KEY=your_zhipu_api_key_here

LLM_PROVIDER=qianwen          # qianwen 或 zhipu
LLM_MODEL=qwen-plus           # 文本模型
LLM_VISION_MODEL=qwen-vl-plus # 图片识别模型（可选，留空则跳过图片分析）

# ===== 企业邮箱 IMAP =====
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USER=sales@yourdomain.com
IMAP_PASS=your_email_password

# ===== SMTP 发信（不填则复用 IMAP 凭据）=====
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465                # 465=SSL直连  587=STARTTLS（Outlook/Office365）
# SMTP_USER=sales@yourdomain.com
# SMTP_PASS=your_email_password

# ===== 应用配置 =====
DB_PATH=/data/email_reply.db
PRODUCTS_CSV=/data/products.csv
POLL_INTERVAL=60              # 轮询间隔（秒）
INIT_SYNC_DAYS=90             # 首次登录拉取历史邮件的天数范围

# ===== 认证 =====
# 留空则首次启动自动生成；修改后数据库内加密密码会失效
SECRET_KEY=

# ===== 公司信息（写入草稿签名，也可登录后在 /settings/company 填写）=====
COMPANY_NAME=Your Company Ltd.
COMPANY_DESC=a manufacturer and exporter of carbide products
COMPANY_WEBSITE=https://www.yourcompany.com
COMPANY_EMAIL=sales@yourcompany.com
COMPANY_PHONE=+86-xxx-xxxx-xxxx

# ===== 可选功能 =====
# SERPER_API_KEY=your_serper_api_key_here   # 买家背调 Google 搜索，留空则跳过
# NOTIFY_EMAIL=admin@yourdomain.com         # 新草稿生成后发邮件通知，留空则关闭
# SYSTEM_URL=https://your-domain.com        # 通知邮件中的系统链接
