# ===== LLM =====
# 二选一填写
QIANWEN_API_KEY=your_qianwen_api_key_here
# ZHIPU_API_KEY=your_zhipu_api_key_here

LLM_PROVIDER=qianwen          # qianwen 或 zhipu
LLM_MODEL=qwen-plus           # 可选，默认 qwen-plus

# ===== 企业邮箱 IMAP =====
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USER=sales@yourdomain.com
IMAP_PASS=your_email_password

# ===== 应用配置 =====
DB_PATH=email_reply.db
PRODUCTS_CSV=products.csv
POLL_INTERVAL=60              # 轮询间隔（秒）
INIT_SYNC_DAYS=90             # 首次登录拉取历史邮件的天数范围

# ===== 认证 =====
# 必须修改，可用 openssl rand -hex 32 生成
SECRET_KEY=replace_with_a_random_64_char_string

# ===== 背调搜索（可选）=====
# SERPER_API_KEY=your_serper_api_key_here

# ===== 通知邮件（可选）=====
# NOTIFY_EMAIL=admin@yourdomain.com
# SYSTEM_URL=https://your-server-ip

# ===== 公司信息（写入邮件签名，也可登录后在设置页填写）=====
# COMPANY_NAME=Your Company Name
# COMPANY_WEBSITE=https://yourcompany.com
# COMPANY_EMAIL=sales@yourdomain.com
# COMPANY_PHONE=+86-xxx-xxxx-xxxx
